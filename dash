#!/usr/bin/env bash
# Janus Dashboard launcher — run from anywhere in the repo
# Usage: ./dash
set -e

# Always load dotfiles env so the bridge has every API key (OPENAI_API_KEY,
# GOOGLE_REFRESH_TOKEN, SNOWFLAKE_*, etc.) regardless of how this script was
# invoked. Interactive shells already do this via .bashrc, but backgrounded /
# detached / hook-invoked starts don't inherit it. Idempotent.
if [ -f "$HOME/.env" ]; then
  set -a
  . "$HOME/.env"
  set +a
fi

# Two-mode launcher:
#   1) Run from janus-ia directly: ./dash            → WORKSPACE_ROOT=/workspaces/janus-ia
#   2) Run from a wrapper in another repo: the wrapper sets JANUS_DASH_HOME to
#      the janus-ia clone and exports WORKSPACE_ROOT=<caller's repo> before
#      exec-ing this script. Then DASH points at janus-ia's dashboard/ but the
#      bridge reads/writes the caller's workspace.
#
# When WORKSPACE_ROOT is unset (mode 1), default to the repo containing this
# script so everything continues to work in janus-ia.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -z "${WORKSPACE_ROOT:-}" ]; then
  WORKSPACE_ROOT="$SCRIPT_DIR"
fi
export WORKSPACE_ROOT

# Find the janus-ia dashboard regardless of where we were invoked from.
DASH_HOME="${JANUS_DASH_HOME:-$SCRIPT_DIR}"
DASH="$DASH_HOME/dashboard"
PORT="${VENTURE_OS_PORT:-3100}"

cd "$DASH"

# Ensure npm/npx are on PATH. On Windows Git Bash / MSYS, fresh shells won't see
# the MSI-installed Node until restart — so probe common install locations and
# prepend whichever one is present. Idempotent: no-op if npm is already found.
if ! command -v npm >/dev/null 2>&1; then
  for candidate in \
    "/c/Program Files/nodejs" \
    "/c/Program Files (x86)/nodejs" \
    "$HOME/AppData/Local/Programs/nodejs" \
    "$HOME/scoop/apps/nodejs/current"; do
    if [ -x "$candidate/npm.cmd" ] || [ -x "$candidate/npm" ]; then
      export PATH="$candidate:$PATH"
      echo "• found node at $candidate"
      break
    fi
  done
fi
if ! command -v npm >/dev/null 2>&1; then
  echo "✗ npm not found. Install Node.js LTS (winget install OpenJS.NodeJS.LTS) and reopen the shell." >&2
  exit 1
fi

# Kill any stale process on the port. lsof isn't available on Windows Git Bash,
# so fall back to netstat + taskkill when running under MSYS/MINGW.
kill_port() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    local pid
    pid=$(lsof -ti :"$port" 2>/dev/null || true)
    [ -n "$pid" ] && kill $pid 2>/dev/null || true
    [ -n "$pid" ] && echo "• killed stale process on :$port"
  elif command -v netstat >/dev/null 2>&1 && command -v taskkill >/dev/null 2>&1; then
    # Windows: parse PID from `netstat -ano` LISTENING lines for this port
    local pids
    pids=$(netstat -ano | grep -E "LISTENING[[:space:]]+[0-9]+$" | grep -E ":$port[[:space:]]" | awk '{print $NF}' | sort -u)
    if [ -n "$pids" ]; then
      for pid in $pids; do
        taskkill //F //PID "$pid" >/dev/null 2>&1 || true
      done
      echo "• killed stale process on :$port"
    fi
  fi
}
kill_port "$PORT"
sleep 0.3

# Install deps if missing
if [ ! -d "node_modules" ]; then
  echo "• installing bridge deps..."
  npm install --silent
fi
if [ ! -d "frontend/node_modules" ]; then
  echo "• installing frontend deps..."
  (cd frontend && npm install --silent)
fi

# Rebuild frontend only if sources are newer than the built bundle
NEEDS_BUILD=1
if [ -d "frontend/dist/assets" ]; then
  newest_src=$(find frontend/src frontend/index.html -type f -newer frontend/dist/index.html 2>/dev/null | head -1)
  [ -z "$newest_src" ] && NEEDS_BUILD=0
fi
if [ "$NEEDS_BUILD" = "1" ]; then
  echo "• building frontend..."
  npm run build:frontend --silent
else
  echo "• frontend up to date, skipping build"
fi

# Codex CLI stores creds in ~/.codex/ — OPENAI_API_KEY in env alone is NOT
# enough. If the key is present but codex isn't logged in, install it silently.
if command -v codex >/dev/null 2>&1 && [ -n "${OPENAI_API_KEY:-}" ]; then
  if ! codex login status 2>&1 | grep -q "Logged in"; then
    echo "• installing OpenAI key into codex credential store..."
    printf "%s" "$OPENAI_API_KEY" | codex login --with-api-key >/dev/null 2>&1 \
      && echo "  ✓ codex logged in" \
      || echo "  ⚠ codex login failed — codex agent may not work until you run: printenv OPENAI_API_KEY | codex login --with-api-key"
  fi
fi

echo "• workspace: $WORKSPACE_ROOT"
echo "• starting dashboard on http://localhost:$PORT"
echo ""
exec npx tsx bin/venture-os.ts
